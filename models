#!/bin/bash
# models.sh — No registry, just scan ~/.models/

set -e

MODELS_DIR="$HOME/.models"

# ─── SCAN ──────────────────────────────────────────────────────────────────────

scan_models() {
    local result=()
    if [[ -d "$MODELS_DIR" ]]; then
        for f in "$MODELS_DIR"/*.gguf; do
            [[ -f "$f" ]] || continue
            [[ "$(basename "$f")" == .cache* ]] && continue
            local name=$(basename "$f")
            local size=$(stat -f%z "$f" 2>/dev/null || echo 0)
            result+=("$name|$size")
        done
    fi
    printf '%s\n' "${result[@]}" | sort
}

# ─── COMMANDS ─────────────────────────────────────────────────────────────────

cmd_download() {
    local target="$1"
    [[ -z "$target" ]] && { echo "Usage: models download <HF_repo_id>"; return 1; }

    # Determine repo and file
    local repo file
    if [[ "$target" == *"/"* ]]; then
        repo="$target"
        echo "Looking up files in $repo ..."
        file=$(curl -sL "https://huggingface.co/api/models/$repo" 2>/dev/null | python3 -c "
import sys,json
try:
    d=json.load(sys.stdin)
    for f in d.get('siblings',[]):
        n=f.get('rfilename','')
        if 'Q4_K_M' in n and n.endswith('.gguf'): print(n); sys.exit(0)
    for f in d.get('siblings',[]):
        n=f.get('rfilename','')
        if n.endswith('.gguf'): print(n); sys.exit(0)
except: pass
" 2>/dev/null)
        if [[ -z "$file" ]]; then
            echo "✗ No .gguf file found in $repo"
            return 1
        fi
        echo "  Found: $file"
    else
        echo "✗ Invalid: $target (use HF repo ID like: unsloth/Qwen3.5-9B-GGUF)"
        return 1
    fi

    local path="$MODELS_DIR/$file"
    if [[ -f "$path" ]]; then
        echo "✓ Already downloaded: $path"
        return
    fi

    echo "Downloading to ~/.models/ ..."
    if command -v uv &> /dev/null; then
        uvx hf download "$repo" --include "$file" --local-dir "$MODELS_DIR" 2>&1
    elif command -v hf &> /dev/null; then
        hf download "$repo" --include "$file" --local-dir "$MODELS_DIR" 2>&1
    else
        curl -L -C - -o "$path" "https://huggingface.co/$repo/resolve/main/$file" 2>&1
    fi

    if [[ -f "$path" ]]; then
        echo "✓ Downloaded: $path ($(du -h "$path" | cut -f1))"
    else
        echo "✗ Download failed"
        return 1
    fi
}

cmd_list() {
    echo "=== Models in ~/.models/ ==="
    printf "%-50s %10s %12s\n" "FILE" "SIZE" "STATUS"
    printf "%-50s %10s %12s\n" "----" "----" "------"

    local current=""
    if pgrep -f llama-server > /dev/null 2>&1; then
        current=$(pgrep -f llama-server | head -1 | xargs ps -o args= -p 2>/dev/null | grep -o "\-m [^ ]*" | cut -d' ' -f2)
        current=$(basename "$current" 2>/dev/null)
    fi

    while IFS='|' read -r name size; do
        [[ -z "$name" ]] && continue
        local hsize=$(numfmt --to=iec-i --suffix=B "$size" 2>/dev/null || echo "${size}B")
        local status="—"
        [[ "$name" == "$current" ]] && status="● running"
        printf "%-50s %10s %12s\n" "$name" "$hsize" "$status"
    done < <(scan_models)

    echo ""
    echo "=== Server ==="
    if pgrep -f llama-server > /dev/null 2>&1; then
        local pid=$(pgrep -f llama-server | head -1)
        local mem=$(ps -o rss= -p "$pid" 2>/dev/null | awk '{printf "%.0f MB", $1/1024}')
        echo "  PID:   $pid"
        echo "  RAM:   $mem"
    else
        echo "  (not running)"
    fi
    echo ""
    echo "=== Disk ==="
    echo "  Models: $(du -sh "$MODELS_DIR" 2>/dev/null | cut -f1)"
    echo "  Free:   $(df -h / | tail -1 | awk '{print $4}')"
}

cmd_serve() {
    local model="$1"
    [[ -z "$model" ]] && { echo "Usage: models serve <filename>"; cmd_list; return 1; }

    local path="$MODELS_DIR/$model"
    [[ ! -f "$path" ]] && { echo "✗ Not found: $path"; return 1; }

    # Stop existing
    pkill -f llama-server 2>/dev/null || true
    sleep 2

    echo "Serving: $model"
    nohup llama-server \
        -m "$path" -ngl 99 --ctx-size 16384 --threads 8 \
        --cache-type-k q8_0 --cache-type-v q8_0 \
        -fa auto --tools all --jinja --ui-mcp-proxy \
        --host 127.0.0.1 --port 11434 --sleep-idle-seconds 180 \
        > /dev/null 2>&1 &

    for i in $(seq 1 20); do
        if curl -s http://127.0.0.1:11434/health > /dev/null 2>&1; then
            echo "✓ Server ready on http://127.0.0.1:11434"
            return
        fi
        sleep 1
    done
    echo "⚠ Still loading, check: tail -f ~/.llama-server-error.log"
}

cmd_current() {
    pgrep -f llama-server | head -1 | xargs ps -o args= -p 2>/dev/null || echo "(not running)"
}

cmd_delete() {
    local model="$1"
    [[ -z "$model" ]] && { echo "Usage: models delete <filename>"; return 1; }
    local path="$MODELS_DIR/$model"
    if [[ -f "$path" ]]; then
        rm -f "$path"
        echo "✓ Deleted: $path"
    else
        echo "✗ Not found: $model"
    fi
}

# ─── MAIN ─────────────────────────────────────────────────────────────────────

case "${1:-list}" in
    download)   cmd_download "$@" ;;
    list)       cmd_list ;;
    serve)      cmd_serve "$@" ;;
    current)    cmd_current ;;
    delete)     cmd_delete "$@" ;;
    *)
        echo "Usage: models <download|list|serve|current|delete>"
        echo ""
        echo "  models download <HF_repo>   — download from HF (e.g. unsloth/Qwen3.5-9B-GGUF)"
        echo "  models list                 — show all models in ~/.models/"
        echo "  models serve <filename>     — start server with model"
        echo "  models current              — show running model"
        echo "  models delete <filename>    — remove model file"
        ;;
esac
